{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.alfares.cz/flipflop.customer_journey.events.v1.schema.json",
  "title": "flipflop.customer_journey.events.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "event_name",
    "version",
    "occurred_at",
    "journey_id",
    "correlation_id",
    "causation_id",
    "idempotency_key",
    "source",
    "environment",
    "identifiers",
    "metadata"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "pattern": "^evt_[a-z0-9][a-z0-9_-]{11,127}$"
    },
    "event_name": {
      "type": "string",
      "enum": [
        "session_started",
        "product_viewed",
        "cart_item_added",
        "checkout_started",
        "customer_identity_resolved",
        "shipping_option_selected",
        "cart_validated",
        "payment_attempt_started",
        "payment_succeeded",
        "order_created",
        "order_confirmation_email_queued",
        "order_confirmation_email_sent",
        "marketing_handoff_requested",
        "marketing_handoff_accepted"
      ]
    },
    "version": {
      "const": "1.0.0"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "processed_at": {
      "type": "string",
      "format": "date-time"
    },
    "journey_id": {
      "type": "string",
      "pattern": "^journey_[a-z0-9][a-z0-9_-]{8,127}$"
    },
    "correlation_id": {
      "type": "string",
      "pattern": "^corr_[a-z0-9][a-z0-9_-]{8,127}$"
    },
    "causation_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "idempotency_key": {
      "type": "string",
      "pattern": "^flipflop:[a-z0-9_:-]{8,180}$"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "service",
        "component",
        "producer"
      ],
      "properties": {
        "service": {
          "const": "flipflop"
        },
        "component": {
          "type": "string"
        },
        "producer": {
          "type": "string"
        },
        "route": {
          "type": "string"
        }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "enum": [
            "production",
            "staging",
            "test",
            "development",
            "synthetic"
          ]
        },
        "release": {
          "type": [
            "string",
            "null"
          ]
        },
        "commit_sha": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "identifiers": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "storefront_id"
      ],
      "properties": {
        "anonymous_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "session_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "customer_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "auth_subject": {
          "type": [
            "string",
            "null"
          ]
        },
        "cart_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "checkout_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "payment_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "payment_provider_reference": {
          "type": [
            "string",
            "null"
          ]
        },
        "order_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "email_message_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "marketing_handoff_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "storefront_id": {
          "const": "flipflop"
        }
      }
    },
    "commercial": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "currency",
        "precision"
      ],
      "properties": {
        "currency": {
          "type": "string",
          "enum": [
            "CZK"
          ]
        },
        "subtotal_amount": {
          "type": [
            "number",
            "null"
          ]
        },
        "discount_amount": {
          "type": [
            "number",
            "null"
          ]
        },
        "shipping_amount": {
          "type": [
            "number",
            "null"
          ]
        },
        "tax_amount": {
          "type": [
            "number",
            "null"
          ]
        },
        "total_amount": {
          "type": [
            "number",
            "null"
          ]
        },
        "precision": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        },
        "item_count": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "coupon_ids": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        }
      }
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "product_id"
        ],
        "properties": {
          "product_id": {
            "type": "string"
          },
          "sku": {
            "type": [
              "string",
              "null"
            ]
          },
          "variant_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "quantity": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 1
          },
          "unit_price": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "amount": {
                "type": [
                  "number",
                  "null"
                ]
              },
              "currency": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "precision": {
                "type": [
                  "integer",
                  "null"
                ],
                "minimum": 0,
                "maximum": 4
              }
            }
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "channel",
        "synthetic"
      ],
      "properties": {
        "channel": {
          "type": "string",
          "enum": [
            "web",
            "mobile_web",
            "admin",
            "synthetic"
          ]
        },
        "synthetic": {
          "type": "boolean"
        },
        "locale": {
          "type": "string"
        },
        "cart_valid": {
          "type": "boolean"
        },
        "marketing_consent": {
          "type": "boolean"
        },
        "shipping_method": {
          "type": "string"
        },
        "payment_method": {
          "type": "string"
        },
        "handoff_target": {
          "type": "string"
        }
      }
    }
  },
  "x-contract-rules": {
    "contract_name": "flipflop.customer_journey.events.v1",
    "exchange": "flipflop.customer_journey.events.v1",
    "routing_key_pattern": "customer_journey.{event_name}",
    "required_events_before_ai": [
      "session_started",
      "product_viewed",
      "cart_item_added",
      "checkout_started",
      "customer_identity_resolved",
      "shipping_option_selected",
      "cart_validated",
      "payment_attempt_started",
      "payment_succeeded",
      "order_created",
      "order_confirmation_email_queued",
      "order_confirmation_email_sent",
      "marketing_handoff_requested",
      "marketing_handoff_accepted"
    ],
    "minimum_event_set_required_before_ai_optimization": [
      "session_started",
      "product_viewed",
      "cart_item_added",
      "checkout_started",
      "customer_identity_resolved",
      "shipping_option_selected",
      "cart_validated",
      "payment_attempt_started",
      "payment_succeeded",
      "order_created",
      "order_confirmation_email_queued",
      "order_confirmation_email_sent",
      "marketing_handoff_requested",
      "marketing_handoff_accepted"
    ],
    "event_required_identifiers": {
      "session_started": [
        "anonymous_id",
        "session_id"
      ],
      "product_viewed": [
        "anonymous_id",
        "session_id"
      ],
      "cart_item_added": [
        "cart_id"
      ],
      "checkout_started": [
        "cart_id",
        "checkout_id"
      ],
      "customer_identity_resolved": [
        "customer_id"
      ],
      "shipping_option_selected": [
        "checkout_id"
      ],
      "cart_validated": [
        "cart_id",
        "checkout_id"
      ],
      "payment_attempt_started": [
        "checkout_id",
        "payment_id"
      ],
      "payment_succeeded": [
        "checkout_id",
        "payment_id",
        "order_id"
      ],
      "order_created": [
        "order_id"
      ],
      "order_confirmation_email_queued": [
        "order_id"
      ],
      "order_confirmation_email_sent": [
        "order_id"
      ],
      "marketing_handoff_requested": [
        "customer_id",
        "order_id"
      ],
      "marketing_handoff_accepted": [
        "customer_id",
        "order_id",
        "marketing_handoff_id"
      ]
    },
    "correlation_strategy": {
      "journey_id": "Created at first observed session and propagated through cart, checkout, order, payment, email, and marketing handoff metadata.",
      "correlation_id": "One stable customer journey correlation ID per successful funnel; AMQP correlationId equals envelope correlation_id.",
      "causation_id": "Previous event_id when known, otherwise null for the first event or runtime boundaries without a reliable predecessor.",
      "idempotency_key": "Deterministic key scoped as flipflop:{event_name}:{business_object_id}:{transition_or_sequence}."
    },
    "forbidden_raw_sensitive_fields": [
      "email",
      "phone",
      "firstName",
      "lastName",
      "address",
      "street",
      "city",
      "postalCode",
      "token",
      "password",
      "cardNumber"
    ]
  }
}
