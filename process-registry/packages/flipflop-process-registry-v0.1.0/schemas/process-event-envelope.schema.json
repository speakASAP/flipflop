{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://flipflop.local/schemas/process-event-envelope.schema.json",
  "title": "FlipFlop Process Event Envelope",
  "description": "Runtime event emitted when application code observes or applies a process transition.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "occurred_at",
    "process_key",
    "process_version",
    "transition",
    "source_entity",
    "actor",
    "validation_result",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "process_key": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(\\.[a-z][a-z0-9_]*)+$"
    },
    "process_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "transition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from_step", "to_step", "event"],
      "properties": {
        "from_step": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "to_step": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "event": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        }
      }
    },
    "source_entity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id"],
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["customer", "staff", "system", "integration"]
        },
        "id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "validation_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision", "rule_refs"],
      "properties": {
        "decision": {
          "type": "string",
          "enum": ["accepted", "rejected", "blocked"]
        },
        "rule_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "reason": {
          "type": "string",
          "default": ""
        }
      }
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
