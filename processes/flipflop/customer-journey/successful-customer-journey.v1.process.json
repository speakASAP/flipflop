      "required_fields": ["event_id", "event_name", "version", "occurred_at", "journey_id", "correlation_id", "causation_id", "idempotency_key", "source.service", "source.component", "environment.name", "metadata.channel", "identifiers.customer_id"],
      "forbidden_fields": ["raw card data", "raw JWT/access tokens", "passwords", "provider secrets", "raw payment credentials", "unapproved raw PII"]
    },
    {
      "name": "marketing_handoff_requested",
      "version": 1,
      "producer": "marketing-microservice",
      "required_fields": ["event_id", "event_name", "version", "occurred_at", "journey_id", "correlation_id", "causation_id", "idempotency_key", "source.service", "source.component", "environment.name", "metadata.channel", "identifiers.customer_id"],
      "forbidden_fields": ["raw card data", "raw JWT/access tokens", "passwords", "provider secrets", "raw payment credentials", "unapproved raw PII"]
    }
  ],
  "guards": [
