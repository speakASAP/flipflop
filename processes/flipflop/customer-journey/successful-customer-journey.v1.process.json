      "producer": "flipflop checkout",
      "required_fields": ["event_id", "event_name", "version", "occurred_at", "journey_id", "correlation_id", "causation_id", "idempotency_key", "source.service", "source.component", "environment.name", "metadata.channel", "identifiers.session_id"],
      "forbidden_fields": ["raw card data", "raw JWT/access tokens", "passwords", "provider secrets", "raw payment credentials", "unapproved raw PII"]
    },
    {
      "name": "payment_succeeded",
      "version": 1,
      "producer": "payments-microservice",
      "required_fields": ["event_id", "event_name", "version", "occurred_at", "journey_id", "correlation_id", "causation_id", "idempotency_key", "source.service", "source.component", "environment.name", "metadata.channel", "identifiers.customer_id"],
      "forbidden_fields": ["raw card data", "raw JWT/access tokens", "passwords", "provider secrets", "raw payment credentials", "unapproved raw PII"]
    },
    {
      "name": "order_created",
      "version": 1,
      "producer": "orders-microservice",
      "required_fields": ["event_id", "event_name", "version", "occurred_at", "journey_id", "correlation_id", "causation_id", "idempotency_key", "source.service", "source.component", "environment.name", "metadata.channel", "identifiers.customer_id"],
      "forbidden_fields": ["raw card data", "raw JWT/access tokens", "passwords", "provider secrets", "raw payment credentials", "unapproved raw PII"]
    },
    {
